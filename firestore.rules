rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function isValidMember(data) {
      return data.keys().hasAll(['name', 'role', 'photoUrl', 'selected', 'createdAt', 'updatedAt'])
        && data.keys().size() == 6
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.role is string && data.role.size() <= 100
        && data.photoUrl is string && data.photoUrl.size() <= 2083
        && data.selected is bool;
    }

    // 2. Shared department member records
    match /members/{memberId} {
      allow read, list: if isSignedIn() && isValidId(memberId);
      allow create: if isSignedIn() && isValidId(memberId) && isValidMember(incoming());
      allow update: if isSignedIn() && isValidId(memberId) && isValidMember(incoming());
      allow delete: if isSignedIn() && isValidId(memberId);
    }
  }
}
